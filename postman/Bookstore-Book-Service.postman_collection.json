    {
      "name": "Admin Catalog",
      "description": "Quản trị sách, ảnh sách và danh mục (/api/v1/admin)",
      "item": [
        {
          "name": "Admin - Books",
          "item": [
            {
              "name": "GET - Danh sách sách admin (phân trang)",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/books?page=0&size=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "admin", "books"],
                  "query": [
                    { "key": "page", "value": "0" },
                    { "key": "size", "value": "10" }
                  ]
                }
              }
            },
            {
              "name": "GET - Chi tiết sách admin",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/books/{{bookId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "admin", "books", "{{bookId}}"]
                }
              }
            },
            {
              "name": "POST - Tạo sách admin",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const json = pm.response.json();",
                      "  if (json.result && json.result.id) {",
                      "    pm.collectionVariables.set('bookId', json.result.id);",
                      "  }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Sách Admin Test {{$timestamp}}\",\n  \"isbn\": \"978-ADMIN-{{$timestamp}}\",\n  \"price\": 199000,\n  \"discountPrice\": 159000,\n  \"importPrice\": 99000,\n  \"stockQuantity\": 100,\n  \"publishDate\": \"2024-01-15\",\n  \"description\": \"Sách tạo từ admin API\",\n  \"status\": \"AVAILABLE\",\n  \"authorIds\": [\"{{authorId}}\"],\n  \"categoryIds\": [\"{{categoryId}}\"]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/admin/books",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "admin", "books"]
                }
              }
            },
            {
              "name": "PUT - Cập nhật sách admin",
              "request": {
                "method": "PUT",
                "header": [
